# Airflow Docker Environment Variables Template
# Copy this file to .env and adjust the values

# Custom image name matching the Dockerfile build
AIRFLOW_IMAGE_NAME=unigap/airflow:2.10.4

# User ID of the host machine (run `id -u` to get this)
# Essential for file permission mapping between host and container
AIRFLOW_UID=1000

# Docker group ID of the host machine (run `getent group docker | cut -d: -f3` to get this)
# Essential for allowing Airflow to spawn Docker containers via DockerOperator
DOCKER_GID=999

# Additional PIP requirements if needed at runtime (usually handled in Dockerfile)
_PIP_ADDITIONAL_REQUIREMENTS='apache-airflow-providers-apache-kafka psycopg[binary] apache-airflow-providers-apache-spark apache-airflow-providers-docker docker apache-airflow-providers-postgres'
