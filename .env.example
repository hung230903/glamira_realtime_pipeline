# ============================================================
# SERVER Kafka (remote cluster — nguồn dữ liệu gốc)
# ============================================================
SERVER_BOOTSTRAP_SERVERS=<host1>:9094,<host2>:9094
SERVER_TOPIC=product_view
SERVER_SECURITY_PROTOCOL=SASL_PLAINTEXT
SERVER_SASL_MECHANISM=PLAIN
SERVER_SASL_USERNAME=your_server_kafka_username
SERVER_SASL_PASSWORD=your_server_kafka_password
SERVER_GROUP_ID=kafka-to-kafka-group
SERVER_AUTO_OFFSET_RESET=earliest

# ============================================================
# LOCAL Kafka (cụm local — Spark đọc từ đây)
# ============================================================
LOCAL_BOOTSTRAP_SERVERS=localhost:9094,localhost:9194,localhost:9294
LOCAL_TOPIC=product_view
LOCAL_SECURITY_PROTOCOL=SASL_PLAINTEXT
LOCAL_SASL_MECHANISM=PLAIN
LOCAL_SASL_USERNAME=your_local_kafka_username
LOCAL_SASL_PASSWORD=your_local_kafka_password
LOCAL_PRODUCER_ACKS=all
LOCAL_GROUP_ID=local-spark-consumer-group
LOCAL_AUTO_OFFSET_RESET=earliest

# ============================================================
# Kafka config cho Spark Structured Streaming
# (Spark chạy trong docker nên dùng tên host của mạng docker)
# ============================================================
KAFKA_BOOTSTRAP_SERVERS=kafka-0:9092,kafka-1:9092,kafka-2:9092
KAFKA_TOPIC=product_view
KAFKA_SASL_MECHANISM=PLAIN
KAFKA_SECURITY_PROTOCOL=SASL_PLAINTEXT
KAFKA_USERNAME=your_local_kafka_username
KAFKA_PASSWORD=your_local_kafka_password

# ============================================================
# Postgres
# ============================================================
POSTGRES_DB=spark_streaming_project
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ============================================================
# App
# ============================================================
CHECKPOINT_PATH=file:///tmp/spark_checkpoints/user_activity
IP2LOCATION_DB_PATH=/spark/IP2LOCATION-LITE-DB11.BIN
# Khi chạy local: APP_LOG_DIR=./logs
# Khi chạy Docker: bỏ trống → tự dùng /tmp/logs (luôn có quyền ghi)
APP_LOG_DIR=./logs
